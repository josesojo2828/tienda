<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= typeof title !== 'undefined' ? title : 'GEEK STORE | Facebook Marketplace' %></title>
  <!-- Google Fonts: Inter para texto y Outfit para logo -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Outfit:wght@800&display=swap" rel="stylesheet">
  <!-- FontAwesome para iconos clásicos -->
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
  <!-- Estilos Globales -->
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>

  <!-- Header Estilo Facebook Marketplace -->
  <header class="fb-header">
    <div class="header-container-fb">
      
      <!-- Lado Izquierdo: Logo y Badge -->
      <div class="header-left">
        <a href="/products" class="logo-fb">GEEKSTORE</a>
        <div class="badge-marketplace">
          <i class="fa-solid fa-store"></i>
          <span>Marketplace</span>
        </div>
      </div>

      <!-- Centro: Buscador -->
      <form class="search-form-fb" action="/products" method="GET">
        <div class="search-input-wrapper-fb">
          <i class="fa-solid fa-magnifying-glass search-icon-fb"></i>
          <input 
            type="text" 
            name="search" 
            class="search-input-fb" 
            placeholder="Buscar en Marketplace..." 
            value="<%= typeof searchQuery !== 'undefined' ? searchQuery : '' %>"
            autocomplete="off"
          >
          <% if (typeof searchQuery !== 'undefined' && searchQuery) { %>
            <button type="button" class="search-clear-btn-fb" onclick="window.location.href='/products'">
              <i class="fa-solid fa-xmark"></i>
            </button>
          <% } %>
        </div>
      </form>

      <!-- Lado Derecho: Iconos Rápidos y Perfil -->
      <div class="header-right">
        <!-- Notificaciones -->
        <button class="header-icon-btn" title="Notificaciones">
          <i class="fa-solid fa-bell"></i>
        </button>
        <!-- Carrito -->
        <button class="header-icon-btn" title="Carrito de compras">
          <i class="fa-solid fa-cart-shopping"></i>
        </button>
        <!-- Perfil Simulado -->
        <div class="header-user-profile" title="Tu perfil de Facebook">
          <i class="fa-solid fa-circle-user"></i>
          <span>Vendedor</span>
        </div>
      </div>

    </div>
  </header>

  <!-- Contenedor Principal de Contenido -->
  <div class="container-fluid">
    <main>
