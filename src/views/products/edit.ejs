<%- include('../layouts/header', { title: 'Modificar publicación - GEEK STORE' }) %>

<div class="form-layout-centered">

  <!-- Alerta de Errores de Validación -->
  <% if (error) { %>
    <div class="ml-alert">
      <div class="ml-alert-icon">
        <i class="fa-solid fa-triangle-exclamation"></i>
      </div>
      <div class="ml-alert-content">
        <h4>Hubo un problema al actualizar la publicación</h4>
        <p><%= error %></p>
      </div>
    </div>
  <% } %>

  <!-- Formulario de Edición Estilo Mercado Libre -->
  <div class="form-card">
    
    <div class="form-header-box">
      <h1 class="form-header-title">Modificar publicación</h1>
      <p class="form-header-subtitle">Actualiza las especificaciones técnicas, precio o inventario de tu artículo para mantener informados a tus clientes.</p>
    </div>

    <form action="/products/<%= product.id %>/edit" method="POST" autocomplete="off">
      <div class="form-grid">
        
        <!-- Nombre del Producto -->
        <div class="form-group">
          <label for="name" class="form-label">Título de la publicación *</label>
          <input 
            type="text" 
            id="name" 
            name="name" 
            class="form-control-input" 
            value="<%= product.name %>"
            required
            minlength="3"
          >
          <span class="form-help-text">Recordá que si el título cambia radicalmente, los motores de búsqueda tardarán más en indexarlo.</span>
        </div>

        <!-- Fila de Precio y Stock -->
        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 20px;">
          <!-- Precio -->
          <div class="form-group">
            <label for="price" class="form-label">Precio ($ USD) *</label>
            <input 
              type="number" 
              id="price" 
              name="price" 
              class="form-control-input" 
              step="0.01" 
              min="0.01" 
              value="<%= product.price %>"
              required
            >
            <span class="form-help-text">El valor final de venta del producto.</span>
          </div>

          <!-- Stock -->
          <div class="form-group">
            <label for="stock" class="form-label">Cantidad en inventario *</label>
            <input 
              type="number" 
              id="stock" 
              name="stock" 
              class="form-control-input" 
              step="1" 
              min="0" 
              value="<%= product.stock %>"
              required
            >
            <span class="form-help-text">Cantidad física que disponés para entrega inmediata.</span>
          </div>
        </div>

        <!-- Descripción -->
        <div class="form-group">
          <label for="description" class="form-label">Descripción técnica</label>
          <textarea 
            id="description" 
            name="description" 
            class="form-control-textarea"
          ><%= product.description || '' %></textarea>
          <span class="form-help-text">Describe las especificaciones técnicas completas de tu producto gaming.</span>
        </div>

        <!-- Botones de Acción -->
        <div class="form-actions-row">
          <a href="/products/<%= product.id %>" class="btn-ml-link">Cancelar edición</a>
          <button type="submit" class="btn-ml-primary">
            <i class="fa-solid fa-floppy-disk"></i> Guardar cambios
          </button>
        </div>

      </div>
    </form>

  </div>

</div>

<%- include('../layouts/footer') %>
