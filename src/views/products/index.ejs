<%- include('../layouts/header', { title: 'GEEK STORE | Facebook Marketplace' }) %>

<div class="catalog-layout-fb">
  
  <!-- Sidebar de Filtros Estilo Facebook Marketplace -->
  <aside class="catalog-sidebar-fb">
    <h2 class="sidebar-title-fb">Marketplace</h2>
    
    <!-- Botón Crear Publicación -->
    <a href="/products/new" class="btn-fb-publish">
      <i class="fa-solid fa-plus"></i> Crear publicación
    </a>
    
    <div class="sidebar-divider-fb"></div>

    <!-- Sección Filtros -->
    <div class="sidebar-section-fb">
      <h3 class="sidebar-section-title-fb">Filtros</h3>
      <div style="font-size: 14px; color: var(--fb-text-dark); display: flex; align-items: center; justify-content: space-between;">
        <span>Ubicación</span>
        <a href="#" style="font-weight: 600; font-size: 13px;">Caracas · 60 km</a>
      </div>
      
      <!-- Filtro de Precio -->
      <form action="/products" method="GET" style="display: flex; flex-direction: column; gap: 8px;">
        <span class="price-range-label-fb" style="font-weight: 600; margin-top: 4px;">Precio</span>
        <div class="price-range-inputs-fb">
          <div class="price-range-box-fb">
            <span class="price-range-label-fb">Mín.</span>
            <input type="number" name="minPrice" class="price-range-field-fb" placeholder="Cualquiera">
          </div>
          <div class="price-range-box-fb">
            <span class="price-range-label-fb">Máx.</span>
            <input type="number" name="maxPrice" class="price-range-field-fb" placeholder="Cualquiera">
          </div>
        </div>
        <button type="submit" class="filter-apply-btn-fb">Aplicar filtros</button>
      </form>
    </div>

    <div class="sidebar-divider-fb"></div>

    <!-- Sección Categorías -->
    <div class="sidebar-section-fb">
      <h3 class="sidebar-section-title-fb">Categorías</h3>
      <nav class="sidebar-menu-list-fb">
        
        <a href="/products" class="sidebar-menu-item-fb active">
          <span class="menu-item-content-fb">
            <span class="menu-icon-wrapper-fb"><i class="fa-solid fa-laptop"></i></span>
            Accesorios para PC
          </span>
          <span class="menu-badge-fb">3</span>
        </a>

        <a href="#" class="sidebar-menu-item-fb">
          <span class="menu-item-content-fb">
            <span class="menu-icon-wrapper-fb"><i class="fa-solid fa-gamepad"></i></span>
            Consolas y Videojuegos
          </span>
          <span class="menu-badge-fb">12</span>
        </a>

        <a href="#" class="sidebar-menu-item-fb">
          <span class="menu-item-content-fb">
            <span class="menu-icon-wrapper-fb"><i class="fa-solid fa-headphones"></i></span>
            Audio y Video
          </span>
          <span class="menu-badge-fb">8</span>
        </a>

        <a href="#" class="sidebar-menu-item-fb">
          <span class="menu-item-content-fb">
            <span class="menu-icon-wrapper-fb"><i class="fa-solid fa-desktop"></i></span>
            Monitores y Pantallas
          </span>
          <span class="menu-badge-fb">5</span>
        </a>

      </nav>
    </div>
  </aside>

  <!-- Feed de Ventas del Marketplace -->
  <section class="catalog-main-fb">
    
    <div class="catalog-header-fb">
      <h1 class="catalog-header-title-fb">Ofertas de hoy</h1>
      <p class="catalog-header-subtitle-fb">Caracas, Distrito Capital · En un radio de 60 kilómetros</p>
    </div>

    <% if (products && products.length > 0) { %>
      <div class="products-grid-fb">
        <% products.forEach(product => { 
          // Selección dinámica de imagen de Unsplash según palabras clave en el nombre
          let imageUrl = "https://images.unsplash.com/photo-1546868871-7041f2a55e12?w=500&auto=format&fit=crop&q=60"; // Default gadget
          const nameLower = product.name.toLowerCase();
          
          if (nameLower.includes('silla')) {
            imageUrl = "https://images.unsplash.com/photo-1592078615290-033ee584e267?w=500&auto=format&fit=crop&q=60";
          } else if (nameLower.includes('teclado')) {
            imageUrl = "https://images.unsplash.com/photo-1618384887929-16ec33fab9ef?w=500&auto=format&fit=crop&q=60";
          } else if (nameLower.includes('monitor')) {
            imageUrl = "https://images.unsplash.com/photo-1527443224154-c4a3942d3acf?w=500&auto=format&fit=crop&q=60";
          }
        %>
          <div class="product-card-fb" onclick="window.location.href='/products/<%= product.id %>'">
            
            <!-- Imagen con badge de stock e iconos rápidos flotantes -->
            <div class="product-card-image-box-fb">
              <% if (product.stock > 10) { %>
                <span class="card-badge-fb in-stock">Disponible</span>
              <% } else if (product.stock > 0) { %>
                <span class="card-badge-fb few-stock">¡Últimas <%= product.stock %>!</span>
              <% } else { %>
                <span class="card-badge-fb out-stock">Agotado</span>
              <% } %>
              
              <!-- Botones flotantes administrativos de Facebook -->
              <div class="product-card-actions-fb" onclick="event.stopPropagation();">
                <a href="/products/<%= product.id %>/edit" class="btn-card-action-fb" title="Editar publicación">
                  <i class="fa-regular fa-pen-to-square"></i>
                </a>
                <form action="/products/<%= product.id %>/delete" method="POST" style="display: inline;">
                  <button type="submit" class="btn-card-action-fb delete" title="Eliminar publicación" onclick="return confirm('¿Seguro que querés eliminar esta publicación?')">
                    <i class="fa-regular fa-trash-can"></i>
                  </button>
                </form>
              </div>

              <img src="<%= imageUrl %>" alt="<%= product.name %>">
            </div>

            <!-- Información (Estilo Chato Marketplace) -->
            <div class="product-card-info-fb">
              <span class="product-card-price-fb">$<%= product.price.toLocaleString('es-VE', { minimumFractionDigits: 2, maximumFractionDigits: 2 }) %></span>
              <span class="product-card-title-fb"><%= product.name %></span>
              <span class="product-card-location-fb">Caracas</span>
            </div>

          </div>
        <% }) %>
      </div>
    <% } else { %>
      <div class="catalog-empty-state-fb">
        <div class="catalog-empty-icon-fb">
          <i class="fa-solid fa-magnifying-glass"></i>
        </div>
        <h3>No se encontraron publicaciones</h3>
        <p>Parece que no hay productos cargados que coincidan con la búsqueda. ¡Animate a crear la primera publicación!</p>
        <a href="/products/new" class="btn-fb-publish" style="margin-top: 10px; background-color: var(--fb-blue); color: var(--fb-white);">
          <i class="fa-solid fa-plus"></i> Crear publicación
        </a>
      </div>
    <% } %>

  </section>

</div>

<%- include('../layouts/footer') %>
