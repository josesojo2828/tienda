<%- include('../layouts/header', { title: product.name + ' - GEEK STORE' }) %>

<div class="product-detail-layout-fb">
  
  <!-- Lado Izquierdo: Canvas Oscuro de Imagen con Botón Atrás -->
  <div class="detail-gallery-canvas-fb">
    <a href="/products" class="detail-back-button-fb" title="Volver al listado">
      <i class="fa-solid fa-arrow-left"></i>
    </a>
    
    <% 
      // Selección dinámica de la misma imagen de Unsplash según palabras clave en el nombre del producto
      let imageUrl = "https://images.unsplash.com/photo-1546868871-7041f2a55e12?w=800&auto=format&fit=crop&q=60";
      const nameLower = product.name.toLowerCase();
      if (nameLower.includes('silla')) {
        imageUrl = "https://images.unsplash.com/photo-1592078615290-033ee584e267?w=800&auto=format&fit=crop&q=60";
      } else if (nameLower.includes('teclado')) {
        imageUrl = "https://images.unsplash.com/photo-1618384887929-16ec33fab9ef?w=800&auto=format&fit=crop&q=60";
      } else if (nameLower.includes('monitor')) {
        imageUrl = "https://images.unsplash.com/photo-1527443224154-c4a3942d3acf?w=800&auto=format&fit=crop&q=60";
      }
    %>
    <img src="<%= imageUrl %>" alt="<%= product.name %>" class="detail-gallery-image-fb">
  </div>

  <!-- Lado Derecho: Sidebar Blanco de Información Detallada -->
  <aside class="detail-info-sidebar-fb">
    <div class="sidebar-content-fb">
      
      <!-- Metadatos de Publicación -->
      <div class="detail-meta-fb">
        Publicado hace 3 horas en Caracas
      </div>
      
      <!-- Título de la Publicación -->
      <h1 class="detail-title-fb"><%= product.name %></h1>
      
      <!-- Precio de Impacto -->
      <div class="detail-price-fb">
        $ <%= product.price.toLocaleString('es-VE', { minimumFractionDigits: 2, maximumFractionDigits: 2 }) %>
      </div>

      <!-- Estado de Stock -->
      <div>
        <% if (product.stock > 10) { %>
          <span class="detail-status-badge-fb in-stock">Disponible (<%= product.stock %> unidades)</span>
        <% } else if (product.stock > 0) { %>
          <span class="detail-status-badge-fb few-stock">¡Últimas <%= product.stock %> unidades!</span>
        <% } else { %>
          <span class="detail-status-badge-fb out-stock">Agotado (Sin Stock)</span>
        <% } %>
      </div>

      <div class="sidebar-divider-fb"></div>

      <!-- Sección Descripción -->
      <div>
        <h3 class="detail-section-title-fb">Detalles</h3>
        <p class="detail-description-fb">
          <%= product.description ? product.description : 'El vendedor no proporcionó una descripción comercial detallada de este artículo.' %>
        </p>
      </div>

      <div class="sidebar-divider-fb"></div>

      <!-- Panel Messenger Simulado -->
      <div class="messenger-panel-fb">
        <div class="messenger-header-fb">
          <i class="fa-brands fa-facebook-messenger"></i>
          <span>Enviar mensaje al vendedor</span>
        </div>
        <div class="messenger-input-wrapper-fb">
          <input type="text" class="messenger-input-fb" value="Hola, ¿sigue disponible?" readonly>
        </div>
        <button type="button" class="btn-messenger-send-fb">
          <i class="fa-solid fa-paper-plane"></i> Enviar mensaje
        </button>
      </div>

      <div class="sidebar-divider-fb"></div>

      <!-- Ubicación y Mapa Simulado -->
      <div class="location-map-box-fb">
        <h3 class="detail-section-title-fb">Ubicación</h3>
        <div class="location-map-details-fb">
          <i class="fa-solid fa-location-dot"></i>
          <span>Caracas, Distrito Capital</span>
        </div>
        <div class="location-circle-map-fb">
          <div class="map-circle-radial-fb">
            <div class="map-pin-fb"></div>
          </div>
        </div>
        <span style="font-size: 12px; color: var(--fb-text-gray); text-align: center; display: block; margin-top: 4px;">
          La ubicación es aproximada para proteger la privacidad del vendedor.
        </span>
      </div>

      <!-- Herramientas Administrativas de Publicación (Consola del Vendedor) -->
      <div class="admin-tools-panel-fb">
        <h3 class="detail-section-title-fb" style="color: #665200; border-bottom-color: #ffe699;">Herramientas de Vendedor</h3>
        
        <a href="/products/<%= product.id %>/edit" class="btn-admin-action-fb edit">
          <i class="fa-regular fa-pen-to-square"></i> Editar publicación
        </a>
        
        <form action="/products/<%= product.id %>/delete" method="POST" onsubmit="return confirm('¿De verdad querés eliminar esta publicación? Se perderá permanentemente del marketplace.');" style="margin: 0;">
          <button type="submit" class="btn-admin-action-fb delete">
            <i class="fa-regular fa-trash-can"></i> Eliminar publicación
          </button>
        </form>
      </div>

    </div>
  </aside>

</div>

<%- include('../layouts/footer') %>
